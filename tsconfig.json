{
  /*
  https://www.typescriptlang.org/tsconfig
  https://github.com/tsconfig/bases#centralized-recommendations-for-tsconfig-bases
  */

  "include": ["src/**/*"],
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // check options
    "strict": true,
    /*
    alwaysStrict
    strictNullChecks
    strictBindCallApply
    strictBuiltinIteratorReturn
    strictFunctionTypes
    strictPropertyInitialization
    noImplicitAny
    noImplicitThis
    useUnknownInCatchVariables
    */
    "alwaysStrict": true,
    "exactOptionalPropertyTypes": true, // "dark" | "light" 强制要求不能为undefined
    "noFallthroughCasesInSwitch": true, // swith穿透
    "noImplicitAny": false, // const a 未显示指定type, 支持默认any
    "noImplicitOverride": false, //是否强制overide关键字
    "noImplicitReturns": false, // method是否强制要写return type
    "noImplicitThis": false, // this是否强制要
    "noPropertyAccessFromIndexSignature": true, // 索引签名不确定存在使用[]访问
    "noUncheckedIndexedAccess": true, // 需要处理对象属性的 | undefined
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "strictBindCallApply": true, //函数调用，参数类型严格校验
    // "strictFunctionTypes": false,
    "strictNullChecks": true,
    "useUnknownInCatchVariables": true,


    // Module   See also https://aka.ms/tsconfig/module
    // "allowArbitraryExtensions": false, 前端使用
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    // "target": "esnext",
    
    "noUncheckedSideEffectImports": true, // 禁止单纯 import xxx
    // "rewriteRelativeImportExtensions": false,
    // "paths": {}, 
    // For nodejs:
    // "lib": ["esnext"],


    // emit
    "sourceMap": false,
    // "downlevelIteration": true,  
    // "emitBOM": false,
    // "mapRoot": "https://my-website.com/debug/sourcemaps/", debug Ts使用

    /*
     No Emit - 
      noEmit
      Do not emit compiler output files like JavaScript source code, source-maps or declarations.
      This makes room for another tool like Babel, or swc to handle converting the TypeScript file to a file which can run inside a JavaScript environment.
      You can then use TypeScript as a tool for providing editor integration, and as a source code type-checker.
    */
    // "noEmit": false,
    "noEmitOnError": true,
    "removeComments": false,
    // "allowJs": false,
    // "checkJs": false,
    "isolatedModules": true, //支持单文件编译，兼容babel...
    "verbatimModuleSyntax": true, //可控import行为，side-effect控制, 开启之后不支持混用ems/cjs
    // "types": ["node"],
    // "declaration": true,
    // "declarationMap": true,


    //language and environment
    "target": "es5",
    /*
    Changing target also changes the default value of lib. You may “mix and match” target and lib settings as desired, 
    but you could just set target for convenience.
    */
    // "lib": ["esnext"], 

    
    "skipLibCheck": true,
  }
}
